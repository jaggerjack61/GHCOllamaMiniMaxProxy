# Copy this file to .env and set ANTHROPIC_AUTH_TOKEN before starting the proxy.

ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
ANTHROPIC_MODEL=MiniMax-M2.7
API_TIMEOUT_MS=3000000
DEFAULT_SYSTEM_PROMPT=You are a helpful assistant.

# Optional metadata overrides exposed to Ollama and OpenAI clients.
# Leave these commented unless you want to customize the advertised model details.
# OLLAMA_MODEL_NAME=MiniMax-M2.7
# OLLAMA_MODEL_ARCHITECTURE=minimax
# OLLAMA_MODEL_BASENAME=MiniMax-M2.7
# OLLAMA_MODEL_CONTEXT_LENGTH=204800
# OLLAMA_MODEL_SIZE=4000000000
# OLLAMA_MODEL_FAMILY=minimax
# OLLAMA_MODEL_FORMAT=proxy
# OLLAMA_MODEL_PARAMETER_SIZE=unknown
# OLLAMA_MODIFIED_AT=2026-01-01T00:00:00Z
# OLLAMA_MODEL_CAPABILITIES=completion,tools,vision